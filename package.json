{
  "name": "ua-anti-spam-bot",
  "version": "1.4.10",
  "private": true,
  "engines": {
    "node": ">=20.x"
  },
  "scripts": {
    "start:bot": "nodemon src/bot/index.ts",
    "start:bot:prod": "tsx src/bot/index.ts",
    "start:userbot:prod": "tsx ./src/userbot/index.ts",
    "start:server": "nodemon ./src/server/index.ts",
    "start:server:prod": "tsx ./src/server/index.ts",
    "start:server:cluster": "(npx pm2 delete all || exit 0) && npx pm2 start ./src/server/index.ts -i max && npx pm2 monit || echo '*** Install PM2 globally'",
    "check-swindler:positives": "tsx ./dataset/scripts/check-swindlers.ts positives",
    "check-swindler:negatives": "tsx ./dataset/scripts/check-swindlers.ts negatives",
    "build": "echo 'TODO: Delete it'",
    "download-swindler": "tsx dataset/scripts/download-swindler-dataset.ts && npm run optimize-swindler",
    "optimize-swindler": "tsx dataset/scripts/optimize-swindler-dataset.ts positives && tsx dataset/scripts/optimize-swindler-dataset.ts negatives",
    "optimize-obscene": "tsx ./dataset/scripts/obscene-optimization.ts",
    "lint": "npm-run-all --parallel lint:js lint:type-check test",
    "track-time": "smile-track",
    "lint:js": "cross-env TIMING=1 npx eslint --cache",
    "lint:js:fix": "npm run lint:js -- --fix",
    "lint:type-check": "tsc --noEmit",
    "format:md": "npx prettier --write \"**/*.md\"",
    "typecheck": "npx tsc --noEmit",
    "test": "npx vitest run",
    "test:coverage": "npx vitest run --coverage",
    "format": "npx prettier . --write",
    "prepare": "husky",
    "codex-prepare": "sh ./scripts/link-codex-skills.sh",
    "postinstall": "patch-package"
  },
  "dependencies": {
