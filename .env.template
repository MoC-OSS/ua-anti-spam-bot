##
# Public base URL of the express server (e.g. the ALB DNS name or ngrok URL for local dev).
# Used to register the alarm webhook with the Stfalcon API on server startup.
# Example: https://my-alb.us-east-1.elb.amazonaws.com
# For local dev with ngrok: https://my-tunnel.ngrok-free.app
#
# Used only for express server. 🖥️
# Production required. ✅
#
# @optional {string}
ALARM_WEBHOOK_BASE_URL=

##
# Shared secret to authenticate incoming alarm webhook calls.
# RSA public key (PEM format) used to verify the `X-Webhook-Signature` header on
# incoming POST /webhook/alarm requests from the Stfalcon API.
# Download the current key from the Stfalcon API docs (see Asana task UABOT-113).
# In multi-line .env files escape newlines as \n, or use a secrets manager in production.
#
# Used only for express server. 🖥️
# Production required. ✅
#
# @optional {string}
ALARM_WEBHOOK_PUBLIC_KEY_PEM=

##
# Port of the express application.
#
# Used only for express server. 🖥️
# Production required. ✅
#
# @optional {number} = 3000
PORT=

##
# Host of the express application.
#
# Used only for express server. 🖥️
# Production required. ✅
#
# @optional {string} = localhost
HOST=



##########
##########
########## TensorFlow configuration. 🤖
##########
##########



##
# Controls the verbosity of TensorFlow C++ backend messages.
# Production Dockerfiles default to 2 (errors only) to suppress:
#   "This TF binary is optimized for AVX2/FMA, rebuild to enable everywhere"
#   "TF-TRT Warning: Could not find TensorRT installations"
#
# 0 = ALL (INFO + WARNING + ERROR + FATAL)
# 1 = WARNING + ERROR + FATAL
# 2 = ERROR + FATAL   ← set in production Dockerfiles
# 3 = FATAL only
#
# Used for both bot and server process. 🤖 🖥️
#
# @optional {string}
TF_CPP_MIN_LOG_LEVEL=

##
# Number of intra-op TF threads (parallelism inside a single op, e.g. matmul).
# Defaults to the number of physical CPU cores when unset.
# Tune to match the vCPU allocation of your ECS task to avoid over-subscription.
#
# Used for both bot and server process. 🤖 🖥️
#
# @optional {string}
TF_NUM_INTRAOP_THREADS=

##
# Number of inter-op TF threads (ops that can run in parallel across the graph).
# For sequential inference workloads (one request at a time) consider setting to 1.
#
# Used for both bot and server process. 🤖 🖥️
#
# @optional {string}
TF_NUM_INTEROP_THREADS=



