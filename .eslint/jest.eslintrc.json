{
  "overrides": [
    {
      "env": {
        "vitest-globals/env": true
      },
      "files": ["src/**/*.test.ts", "src/**/*.spec.ts"],
      "plugins": ["vitest", "vitest-globals"],
      "extends": ["plugin:vitest/legacy-recommended"],
      "rules": { "vitest/prefer-expect-assertions": "off" }
    }
  ]
}
